{
  "functions": {
    "api/handler.js": {
      "includeFiles": "{dist/server.cjs,initialize_reference_tables.sql}"
    }
  },
  "rewrites": [
    {
      "source": "/(api|api/.*)",
      "destination": "/api/handler"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
