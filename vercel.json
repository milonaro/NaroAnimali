{
  "functions": {
    "api/handler.cjs": {
      "includeFiles": [
        "initialize_reference_tables.sql",
        "dist/server.cjs"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(api|api/.*)",
      "destination": "/api/handler"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
